{
  "name": "template-static-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rspack dev",
    "build": "run-s clean build:all",
    "build:all": "rspack build --mode=production",
    "format:scss": "stylelint --fix \"**/*.scss\"",
    "format:ts": "biome check --write src/",
    "format": "run-p format:scss format:ts",
    "clean": "rimraf dist .ssr",
    "predev": "npm run clean"
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.11.0"
  },
  "browserslist": [
    "> 0.2%, not dead",
    "> 0.2% in JP, not dead",
    "not ios < 15",
    "safari > 15, ios > 15"
  ],
  "dependencies": {
    "@s.a.g.a/reset-css": "^0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@kitajs/html": "^5.0.0-next.1",
    "@kitajs/ts-html-plugin": "^5.0.0-next.1",
    "@rspack/cli": "^2.0.0",
    "@rspack/core": "^2.0.0",
    "@rspack/dev-server": "^2.0.0",
    "@types/node": "^24.12.0",
    "autoprefixer": "^10.4.27",
    "npm-run-all2": "^8.0.4",
    "postcss-loader": "^8.2.1",
    "postcss-sort-media-queries": "^6.3.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.98.0",
    "sass-loader": "^16.0.7",
    "stylelint": "^17.5.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.2"
  }
}
