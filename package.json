{
  "name": "template-static-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p watch:ejs watch:assets",
    "build": "run-s clean compile:ejs build:assets",
    "compile:ejs": "ejs-compiler -b src/templates/pages -f \"**/[!_]*.ejs\" -o dist/",
    "watch:ejs": "npm run compile:ejs -- -w",
    "build:assets": "rspack build --mode=production",
    "watch:assets": "rspack dev",
    "format:scss": "stylelint --fix \"**/*.scss\"",
    "format:ts": "biome check --write src/ts/",
    "format": "run-p format:scss format:ts",
    "clean": "rimraf dist",
    "predev": "npm run clean"
  },
  "browserslist": [
    "> 0.2%, not dead",
    "> 0.2% in JP, not dead",
    "not ios < 15",
    "safari > 15, ios > 15"
  ],
  "dependencies": {
    "@s.a.g.a/reset-css": "^0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@rspack/cli": "^2.0.1",
    "@rspack/core": "^2.0.1",
    "@rspack/dev-server": "^2.0.1",
    "@s.a.g.a/ejs-compiler": "^1.0.0",
    "@types/node": "^24.12.0",
    "autoprefixer": "^10.5.0",
    "npm-run-all2": "^8.0.4",
    "postcss-loader": "^8.2.1",
    "postcss-sort-media-queries": "^6.5.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.99.0",
    "sass-loader": "^16.0.7",
    "stylelint": "^17.9.1",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.3"
  }
}
